{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Archive",
  "version": "0.1.0",
  "identifier": "com.fashionvoid.archive-inventory",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Archive",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": { "allow": ["**"] }
      }
    }
  }
}
